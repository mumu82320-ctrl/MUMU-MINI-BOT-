# ─── Core Settings ───────────────────────────
# SESSION_ID: paste your session string here (leave blank to use pair code or QR)
SESSION_ID=

# PHONE_NUMBER: your WhatsApp number with country code (no + or spaces)
# Example: 254712345678
# If set, bot will generate a pair code instead of showing a QR code.
# Visit http://localhost:25680/pair to see your code after starting the bot.
PHONE_NUMBER=

PREFIX=.
BOT_NAME=✦ Mumu ✦ Mini ✦ Bot ✦
DESCRIPTION=*© ✦ Mumu ✦ Mini ✦ Bot ✦*

# ─── Owner Settings ──────────────────────────
OWNER_NAME=✦ Mumu ✦ Mini ✦ Bot ✦
OWNER_NUMBER=263776719736

# ─── Alive Settings ──────────────────────────
ALIVE_IMG=https://files.catbox.moe/5uli5p.jpeg
LIVE_MSG=> MUMU MINI BOT IS ACTIVE ⚡

# ─── Reaction Settings ───────────────────────
AUTO_STATUS_REACT=true
CUSTOM_REACT_EMOJIS=💝,💖,💗,❤️‍🔥,❤️‍🩹,❤️,🩷,🧡,💛,💚,💙,🩵,💜,🤎,🖤,🩶,🤍
AUTO_REACT_NEWSLETTER=true
DELETE_LINKS=false

# ─── Anti Features ───────────────────────────
ANTI_BAD=false
ANTIDELETE_GROUP=true
ANTIDELETE_PRIVATE=true

# ─── Status Settings ─────────────────────────
AUTO_STATUS_SEEN=true
AUTO_STATUS_REPLY=true
AUTO_STATUS_MSG=*👀 Seen by Mumu Mini Bot ✅*

# ─── Mode Settings ───────────────────────────
MODE=both
ALWAYS_ONLINE=true

# ─── Simulation Settings ─────────────────────
AUTO_TYPING=true
AUTO_RECORDING=false
READ_MESSAGE=false

# ─── Debug Settings ──────────────────────────
DEBUG=true
